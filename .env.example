# Server Configuration
PORT=3000
NODE_ENV=development
DATABASE_URL=./stoneaio.db
FRONTEND_URL=http://localhost:3000

# Security & Encryption
# JWT_SECRET: Secret for signing access tokens (15m)
JWT_SECRET="your-super-secret-access-key-change-in-production"
# JWT_REFRESH_SECRET: Secret for signing refresh tokens (30d)
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
# ENCRYPTION_KEY: Must be exactly 64 hex characters (32 bytes) for AES-256-GCM
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# AI Providers
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_KEY=""
REPLICATE_API_KEY=""

# Communication
SENDGRID_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE=""

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Integrations
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SERPER_API_KEY=""

# Infrastructure
CADDY_ADMIN_URL="http://localhost:2019"
BASE_DOMAIN="stoneaio.com"
MAIL_DOMAIN="mail.stoneaio.com"
